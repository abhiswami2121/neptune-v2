# Minimum runtime
POSTGRES_URL=
BETTER_AUTH_SECRET=

# ─── AI Gateway (REQUIRED for model access) ───
# Vercel AI Gateway API key. Format: vck_...
# Create at: https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# ─── Vercel OAuth (required for sign-in) ───
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# ─── GitHub App (required for repo access, pushes, and PRs) ───
# Callback URL: {YOUR_ORIGIN}/api/auth/callback/github (better-auth)
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback (installation sync)
# In the GitHub App settings:
#   1. Use the GitHub App Client ID and Client Secret below
#   2. Make the app public if you want org installs to work cleanly
#   3. Store the private key either as PEM contents with escaped newlines
#      or as a base64-encoded PEM
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# ─── Bring Your Own Keys (BYOK) for per-provider API keys ───
# These are optional if using AI Gateway system credentials.
# Set them to use your own provider accounts with no markup.
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ─── Handoff & Deploy Tokens (required for Neptune Chat → V2 handoff) ───
# VERCEL_TOKEN: Vercel personal access token for project creation and deployment.
#   Create at https://vercel.com/account/tokens — needs "Full Account" scope.
VERCEL_TOKEN=
# VERCEL_TEAM_ID: Your Vercel team ID (slug or team_xxx). Required for Vercel API calls.
VERCEL_TEAM_ID=
# GITHUB_TOKEN: GitHub personal access token for repo creation and PR management.
#   Create at https://github.com/settings/tokens — needs "repo" scope.
GITHUB_TOKEN=

# ─── Internal API Tokens (required for programmatic access) ───
# NEPTUNE_INTERNAL_TOKEN: Internal Bearer token for agent session management,
#   diagnostic endpoint, and cross-service API calls.
NEPTUNE_INTERNAL_TOKEN=
# NEPTUNE_TEST_TOKEN: Bearer token for sandbox-only programmatic access.
#   Used by Neptune Chat's spawnCodingAgent to authenticate with V2's /api/chat (sandbox mode).
NEPTUNE_TEST_TOKEN=

# ─── Deployment Refinements ───
# Canonical production URL for webhook callbacks and metadata
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
# Set to "hobby" to use lower resource defaults for constrained deployments.
# Leave unset for standard behavior.
OPEN_AGENTS_RESOURCE_PROFILE=
# Optional base snapshot for fresh sandboxes. If unset, sandboxes use Vercel's standard Sandbox runtime.
# Use a snapshot created in/accessible to your own Vercel scope.
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=

# ─── Optional Integrations ───
# Voice transcription
ELEVENLABS_API_KEY=
# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# ─── Slack Bridge ───
# SLACK_BOT_TOKEN: Slack bot token for sending lifecycle notifications to #jarvis-admin.
#   Create at https://api.slack.com/apps — needs "chat:write" scope.
SLACK_BOT_TOKEN=
# JARVIS_ADMIN_CHANNEL_ID: Slack channel ID for admin notifications (default: C0AQDDC3HAB).
JARVIS_ADMIN_CHANNEL_ID=
